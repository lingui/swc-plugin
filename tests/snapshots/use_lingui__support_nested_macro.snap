import { useLingui } from '@lingui/react/macro';
import { plural } from '@lingui/core/macro';

function MyComponent() {
  const { t } = useLingui();
  const a = t`Text ${plural(users.length, {
          offset: 1,
          0: "No books",
          1: "1 book",
          other: "\# books"
        })}`;
}


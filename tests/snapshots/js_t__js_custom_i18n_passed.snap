import { custom_i18n } from "./i18n";
custom_i18n._(/*i18n*/ {
    id: "EsCV2T",
    message: "Refresh inbox"
});
custom_i18n._(/*i18n*/ {
    id: "JPS-Xq",
    message: "Refresh {foo} inbox {bar}",
    values: {
        foo: foo,
        bar: bar
    }
});
custom_i18n._(/*i18n*/ {
    id: "xplbye",
    message: "Refresh {0} inbox {bar}",
    values: {
        bar: bar,
        0: foo.bar
    }
});
custom_i18n._(/*i18n*/ {

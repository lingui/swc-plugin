import { Trans as Trans_ } from "@lingui/react";
/* lingui-set context="my context" */ const el = <Trans_ {.../*i18n*/ {
    id: "SSborG",
    values: {
        count: count
    },
    message: "{count, plural, one {# book} other {# books}}",
    context: "my context"
}}/>;

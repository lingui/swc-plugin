import { t } from "@lingui/core/macro";

t`Refresh ${{foo}} inbox`
t`Refresh ${{foo: foo.bar}} inbox`
t`Refresh ${{foo: expr()}} inbox`
t`Refresh ${{foo: bar, baz: qux}} inbox`
t`Refresh ${{}} inbox`
t`Refresh ${{...spread}} inbox`


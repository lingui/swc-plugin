// lingui-set idPrefix="root"
import type { MessageDescriptor } from '@lingui/core';
const X = ()=><p>'</p>;
const Y = ()=><p>`</p>;
// lingui-set idPrefix="different"
const different = {
    a: /*i18n*/ {
        id: "different.a",
        message: "different a"
    },
    b: /*i18n*/ {
        id: "different.b",
        message: "different b"
    }
} as const satisfies Record<string, MessageDescriptor>;

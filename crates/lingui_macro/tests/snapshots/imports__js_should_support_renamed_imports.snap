import { i18n as $_i18n } from "@lingui/core";
$_i18n._(/*i18n*/ {
    id: "0IkKj6",
    message: "Hello World!"
});
$_i18n._(/*i18n*/ {
    id: "kwTAtG",
    message: "{value, plural, one {...} other {...}}",
    values: {
        value: value
    }
});

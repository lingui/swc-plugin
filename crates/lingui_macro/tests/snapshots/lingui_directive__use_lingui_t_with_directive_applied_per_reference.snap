import { useLingui } from '@lingui/react/macro';

function App() {
  const { t } = useLingui();
  /* lingui-set context="first" */
  const msg1 = t`Hello`;
  /* lingui-set context="second" */
  const msg2 = t`World`;
  return msg1 + msg2;
}


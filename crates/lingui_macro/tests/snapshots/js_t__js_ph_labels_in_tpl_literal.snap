import { t, ph } from "@lingui/core/macro";

t`Refresh ${ph({foo})} inbox`
t`Refresh ${ph({foo: foo.bar})} inbox`
t`Refresh ${ph({foo: expr()})} inbox`
t`Refresh ${ph({foo: bar, baz: qux})} inbox`
t`Refresh ${ph({})} inbox`
t`Refresh ${ph({...spread})} inbox`


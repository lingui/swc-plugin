import { Trans as Trans_ } from "@lingui/react";
<Trans_ {.../*i18n*/ {
    id: "USNn2Q",
    values: {
        foo: foo
    },
    components: {
        0: <span/>
    },
    message: "Refresh <0>{foo}</0> inbox"
}}/>;

import { CustomTrans as Trans_ } from "./custom-react";
import { customI18n as $_i18n } from "./custom-core";
$_i18n._(/*i18n*/ {
    id: "EsCV2T",
    message: "Refresh inbox"
});
const exp2 = <Trans_ {.../*i18n*/ {
    id: "custom.id",
    message: "Refresh inbox"
}}/>;
